<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css">
<style>
.tiers{display:grid;gap:20px;margin-top:56px;grid-template-columns:1fr}
@media(min-width:900px){.tiers{grid-template-columns:repeat(3,1fr)}}
.tier{border:1px solid var(--line);border-radius:18px;padding:36px;background:var(--glass);position:relative}
.tier.hot{border-color:var(--violet);box-shadow:0 0 60px -20px rgba(124,108,255,.5)}
.tier .flag{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--violet),#5B4BE0);font-size:11px;font-weight:600;padding:5px 16px;border-radius:100px}
.tier h3{font-size:20px;margin-bottom:6px}
.tier .cost{font-family:'Space Grotesk',sans-serif;font-size:34px;font-weight:700;margin:14px 0 4px}
.tier .per{font-size:13px;color:var(--dim);margin-bottom:24px}
.tier ul{list-style:none;font-size:14px;color:var(--dim)}
.tier li{padding:8px 0;border-bottom:1px solid var(--line)}
.tier li::before{content:"✓ ";color:var(--cyan)}
.tier .btn{width:100%;text-align:center;margin-top:26px}
.roi{border:1px solid var(--line);border-radius:18px;background:var(--glass);padding:40px;margin-top:20px}
.roi-grid{display:grid;gap:32px;grid-template-columns:1fr;align-items:center}
@media(min-width:820px){.roi-grid{grid-template-columns:1fr 1fr}}
.roi .big{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(34px,4.6vw,52px);background:linear-gradient(90deg,var(--ink),var(--cyan));-webkit-background-clip:text;background-clip:text;color:transparent}
.roi p{color:var(--dim);font-size:15px}
.roi .math{font-family:'JetBrains Mono',monospace;font-size:13.5px;color:var(--dim);border-left:2px solid var(--violet);padding-left:18px;margin-top:18px;line-height:2}
.roi .math b{color:var(--ink);font-weight:500}
</style>
</head>
<body>

<div class="orb orb1"></div>
<div class="orb orb2"></div>

