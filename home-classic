<script>
(function(){
  const canvas=document.getElementById('net');
  if(!canvas||!window.THREE)return;
  const reduced=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const scene=new THREE.Scene();
  const camera=new THREE.PerspectiveCamera(60,1,0.1,100);
  camera.position.z=16;
  const renderer=new THREE.WebGLRenderer({canvas,alpha:true,antialias:true});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  function size(){const w=canvas.clientWidth||window.innerWidth,h=canvas.clientHeight||window.innerHeight;renderer.setSize(w,h,false);camera.aspect=w/h;camera.updateProjectionMatrix()}
  size();window.addEventListener('resize',size);
  const N=140,positions=new Float32Array(N*3),velocities=[];
  for(let i=0;i<N;i++){positions[i*3]=(Math.random()-0.5)*26;positions[i*3+1]=(Math.random()-0.5)*15;positions[i*3+2]=(Math.random()-0.5)*10;velocities.push({x:(Math.random()-0.5)*0.012,y:(Math.random()-0.5)*0.012,z:(Math.random()-0.5)*0.006})}
  const geo=new THREE.BufferGeometry();
  geo.setAttribute('position',new THREE.BufferAttribute(positions,3));
  const points=new THREE.Points(geo,new THREE.PointsMaterial({color:0x7C6CFF,size:0.09,transparent:true,opacity:0.9}));
  scene.add(points);
  const maxLinks=700,linePos=new Float32Array(maxLinks*6),lineGeo=new THREE.BufferGeometry();
  lineGeo.setAttribute('position',new THREE.BufferAttribute(linePos,3));
  const lines=new THREE.LineSegments(lineGeo,new THREE.LineBasicMaterial({color:0x5EE6D0,transparent:true,opacity:0.14}));
  scene.add(lines);
  let mx=0,my=0;
  window.addEventListener('pointermove',e=>{mx=(e.clientX/window.innerWidth-0.5);my=(e.clientY/window.innerHeight-0.5)});
  function tick(){
    const p=geo.attributes.position.array;
    for(let i=0;i<N;i++){
      p[i*3]+=velocities[i].x;p[i*3+1]+=velocities[i].y;p[i*3+2]+=velocities[i].z;
      if(Math.abs(p[i*3])>13)velocities[i].x*=-1;
      if(Math.abs(p[i*3+1])>7.5)velocities[i].y*=-1;
      if(Math.abs(p[i*3+2])>5)velocities[i].z*=-1;
    }
    geo.attributes.position.needsUpdate=true;
    let li=0;const th=3.2;
    for(let i=0;i<N&&li<maxLinks;i++)for(let j=i+1;j<N&&li<maxLinks;j++){
      const dx=p[i*3]-p[j*3],dy=p[i*3+1]-p[j*3+1],dz=p[i*3+2]-p[j*3+2];
      if(dx*dx+dy*dy+dz*dz<th*th){
        linePos[li*6]=p[i*3];linePos[li*6+1]=p[i*3+1];linePos[li*6+2]=p[i*3+2];
        linePos[li*6+3]=p[j*3];linePos[li*6+4]=p[j*3+1];linePos[li*6+5]=p[j*3+2];li++;
      }
    }
    for(let k=li*6;k<maxLinks*6;k++)linePos[k]=0;
    lineGeo.attributes.position.needsUpdate=true;
    points.rotation.y+=0.0008;lines.rotation.y+=0.0008;
    camera.position.x+=(mx*3-camera.position.x)*0.03;
    camera.position.y+=(-my*2-camera.position.y)*0.03;
    camera.lookAt(scene.position);
    renderer.render(scene,camera);
    if(!reduced)requestAnimationFrame(tick);
  }
  tick();
  if(reduced)renderer.render(scene,camera);
})();
</script>
